  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.1.4",
    "@vue/test-utils": "^2.4.11",
    "jsdom": "^29.1.1",
    "msw": "^2.14.7",
    "typescript": "^6.0.3",
    "vite": "^5.4.6",
    "vitest": "^4.1.10",
    "vue-tsc": "^3.3.7"
  },
  "msw": {
    "workerDirectory": [
